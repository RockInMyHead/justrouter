# ── Основные ──
NODE_ENV=production
PORT=3000

# ── Админка ──
ADMIN_EMAIL=admin@justrouter.ru
ADMIN_PASSWORD=придумайте_сложный_пароль
ADMIN_USERNAME=admin

# ── Биллтинг (ЮKassa) ──
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://justrouter.ru/account

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=JustRouterBot
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── OpenRouter ──
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_PROXY_URL=
OPENROUTER_MODEL_MAP={}

# ── SMTP (почта для верификации) ──
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ── Дополнительно ──
SITE_URL=https://justrouter.ru
USD_TO_RUB=80
PRICE_MULTIPLIER=3
REGISTRATION_BONUS_RUB=0
REGISTRATION_BONUS_DAYS=7
REFERRAL_BONUS_RUB=200
REFERRAL_PROMO_UNTIL=2026-05-31T23:59:59+03:00
LOW_BALANCE_THRESHOLD=100
EMAIL_CODE_TTL_MINUTES=15
SUPPORT_MODEL_ID=google/gemini-2.5-flash

# ── JustRouter AI Agent (LLM-агент с MiniMax M3) ──
# Включение/выключение AI-агента администратора
JUSTROUTER_AGENT_ENABLED=true

# Прямой API ключ MiniMax M3 (приоритет выше OpenRouter)
JUSTROUTER_MINIMAX_API_KEY=sk-cp-...
JUSTROUTER_MINIMAX_MODEL=minimax-m3
JUSTROUTER_MINIMAX_BASE_URL=https://api.minimaxi.com

# Модель через OpenRouter (если не указан MINIMAX_API_KEY)
JUSTROUTER_OPENROUTER_MODEL=minimax/minimax-m3

# Chat ID Telegram для CEO-отчётов (каждые 12ч)
# Узнать: /start боту @userinfobot, скопировать Your ID
JUSTROUTER_CEO_CHAT_ID=
JUSTROUTER_CEO_MODEL=

# Максимальное количество токенов для ответа агента
JUSTROUTER_AGENT_MAX_TOKENS=4096
